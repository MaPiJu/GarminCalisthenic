# Copy to .env and fill in. .env is gitignored.

# Anthropic API key. If unset, the service serves a built-in sample session
# instead of calling Claude — handy for offline development.
ANTHROPIC_API_KEY=

# Bearer token the watch must send (Authorization: Bearer <token>).
# Must match auth_token provisioned on the device. Defaults to DEV_TOKEN,
# which is the watch's ApiConfig dev default — so it works out of the box.
API_AUTH_TOKEN=DEV_TOKEN

# Port the service listens on. The watch's ApiConfig.BASE_URL should point at
# http://<this-host>:<PORT>/v1 (simulator) — HTTPS is required on a physical device.
PORT=8080
